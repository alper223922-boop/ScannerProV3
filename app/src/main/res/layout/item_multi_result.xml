<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:background="@drawable/card_bg"
    android:layout_marginBottom="10dp" android:padding="14dp">

    <!-- Header row -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="10dp">
        <TextView android:id="@+id/tvSymbol" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:textColor="@color/text_primary" android:textSize="18sp"
            android:textStyle="bold" android:letterSpacing="0.02"/>
        <TextView android:id="@+id/tvDirection" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="11sp"
            android:textStyle="bold" android:layout_marginEnd="12dp"
            android:letterSpacing="0.08"/>
        <TextView android:id="@+id/tvPrice" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="@color/gold"
            android:textSize="16sp" android:textStyle="bold"/>
    </LinearLayout>

    <!-- Signals -->
    <com.google.android.material.chip.ChipGroup android:id="@+id/cgSignals"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"/>

    <!-- Pivot levels -->
    <LinearLayout android:id="@+id/llPivots" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="horizontal"
        android:background="@drawable/pivot_bg" android:padding="8dp"
        android:layout_marginBottom="8dp" android:visibility="gone">
        <TextView android:id="@+id/tvPP" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:textColor="@color/text_secondary" android:textSize="9sp"
            android:gravity="center"/>
        <TextView android:id="@+id/tvR1" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:textColor="@color/red" android:textSize="9sp" android:gravity="center"/>
        <TextView android:id="@+id/tvS1" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:textColor="@color/green" android:textSize="9sp" android:gravity="center"/>
    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/border" android:layout_marginBottom="8dp"/>

    <!-- Stats -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="24S DEGISIM" android:textColor="@color/text_muted"
                android:textSize="8sp" android:letterSpacing="0.1"/>
            <TextView android:id="@+id/tvChange" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="HACIM" android:textColor="@color/text_muted"
                android:textSize="8sp" android:letterSpacing="0.1"/>
            <TextView android:id="@+id/tvVolume" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="@color/text_secondary"
                android:textSize="13sp" android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
